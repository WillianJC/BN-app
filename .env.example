# Server
SERVER_PORT=3001
APP_HOST=localhost
PRODUCTION=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
ENV_FILE_PATH=../.env
TYPEORM_SYNC=false

# Client
CLIENT_PORT=5173
VITE_API_URL=http://localhost:3001
VITE_HTML_LANG=es
VITE_APP_TITLE=InclusiApp
VITE_DEFAULT_PAGE_LIMIT=20

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=bnapp
PG_PASSWORD=bnapp_secret
PG_DB=bnapp
PG_SSLMODE=disabled
PG_SSL_REJECT_UNAUTHORIZED=false

# JWT / Auth
JWT_SECRET=changeme_super_secret_key
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=token
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_MAX_AGE=604800000
BCRYPT_SALT_ROUNDS=10
DEFAULT_USER_ROLE=user

# Business Logic
PENSION_AMOUNT=1200
BONUS_AMOUNT=500
DEFAULT_PAGE_SIZE=20# Server
